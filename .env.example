# Copy this file to `.env` and fill in your local values.
# `.env` is ignored by Git and must not be committed.

# Required for real OpenAI-backed LLM calls.
OPENAI_API_KEY=

# Optional OpenAI-compatible endpoint.
# Leave provider/base URL empty for official OpenAI.
# Ollama example: PANTHEON_OPENAI_PROVIDER=ollama and PANTHEON_OPENAI_BASE_URL=http://localhost:11434/v1
# LM Studio example: PANTHEON_OPENAI_PROVIDER=lm_studio and PANTHEON_OPENAI_BASE_URL=http://localhost:1234/v1
# vLLM example: PANTHEON_OPENAI_PROVIDER=vllm and PANTHEON_OPENAI_BASE_URL=http://localhost:8000/v1
# Local compatible servers usually still need a placeholder OPENAI_API_KEY such as `local`.
PANTHEON_OPENAI_PROVIDER=openai
PANTHEON_OPENAI_BASE_URL=

# Set to 1 to enable OpenAI providers in the CLI/runtime.
PANTHEON_USE_LLM=0

# Set to 1 to try the Phase 5 Agentic Runtime path in CLI.
# Keep it 0 unless you are testing Phase 5 specifically.
PANTHEON_USE_AGENTIC_RUNTIME=0

# Optional high-level play profile.
# Empty = use the explicit switches below.
# local = offline local providers, zero API cost.
# fast = recommended live play: one Creative GM call + local validation/commit.
# quality = more context/output budget for important playtests.
# debug = live play with runtime/debug output enabled.
PANTHEON_PLAY_PROFILE=

# tutorial = fixed Mist Abbey demo map.
# world = Phase 5 agentic world-mode, then choose a playable origin and starting city.
PANTHEON_GAME_MODE=tutorial

# Set to 1 to let Agentic Runtime use OpenAI-backed agents where implemented.
# Default live path uses one low-latency OpenAI Turn Director call.
# Memory and Commit stay local; invalid Rule Arbiter proposals fall back safely.
PANTHEON_USE_AGENTIC_LLM=0

# Set to 1 for the high-freedom Creative GM path.
# This lets one LLM call own the player-facing imagination while Python keeps
# memory, dice, validation, and state authority.
PANTHEON_CREATIVE_GM_MODE=1

# Default 1. Uses one OpenAI call to return intent, adjudication, scene, NPC,
# event, item, and narration together. Set to 0 to use the older multi-call
# Intent + Rule Arbiter + WorldBundle path.
PANTHEON_AGENTIC_TURN_DIRECTOR=1

# Optional slower full-agent mode.
# Set to 1 only when you want NPC/Event/Item agents to call OpenAI separately.
PANTHEON_AGENTIC_FULL_LLM=0

# Pick a model available to your API key.
# Examples: gpt5.5, gpt-4o-mini, gpt-4.1-mini.
PANTHEON_OPENAI_MODEL=gpt5.5

# Live LLM tests are skipped unless this is 1.
# Keep it 0 when you do not want tests to spend API tokens.
# Codex should run live tests only after the user explicitly allows it.
PANTHEON_RUN_LIVE_LLM_TESTS=0

# Optional runtime controls.
PANTHEON_OPENAI_TIMEOUT=60
PANTHEON_OPENAI_MAX_OUTPUT_TOKENS=4000
PANTHEON_RAG_CHAR_LIMIT=8000
# keyword = stable default local canon retrieval.
# embedding = local hash embedding fallback.
# hybrid = keyword + local embedding score.
# vector = SQLite vector cache search.
# vector_hybrid = keyword + SQLite vector cache score.
PANTHEON_CANON_RETRIEVAL=keyword
# local = deterministic local hash embedding.
# openai = real OpenAI embedding API. Use only when you want live embedding calls.
PANTHEON_EMBEDDING_PROVIDER=local
PANTHEON_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PANTHEON_VECTOR_DB_PATH=data/canon_vectors.sqlite3
PANTHEON_SHOW_RUNTIME=0
PANTHEON_PLAIN_PROMPT=1

# Local web UI development origins allowed by FastAPI CORS.
PANTHEON_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set to 1 to force builtin input() instead of prompt_toolkit.
# prompt_toolkit is preferred for Chinese input editing in interactive CLI.
PANTHEON_SIMPLE_INPUT=0
